EXPO_PUBLIC_CONVEX_URL=https://fearless-finch-468.convex.cloud
CHAPA_SECRET_KEY=your_chapa_secret_key_here

# Stitch API key for payment integration
STITCH_API_KEY=your_stitch_api_key_here

# --- OAuth / Social Login (required for Google & Apple sign-in) ---
# Obtain these from your provider's developer console and add to Convex env vars.

# Google OAuth — https://console.cloud.google.com/apis/credentials
# AUTH_GOOGLE_ID=your_google_client_id
# AUTH_GOOGLE_SECRET=your_google_client_secret

# Apple Sign In — https://developer.apple.com/account/resources/services
# AUTH_APPLE_ID=your_apple_service_id
# AUTH_APPLE_SECRET=your_apple_private_key
# AUTH_APPLE_TEAM_ID=your_apple_team_id
# AUTH_APPLE_KEY_ID=your_apple_key_id
